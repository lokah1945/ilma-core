# ========================================================================
# ILMA Core — .gitignore
# ========================================================================
# Bos: Huda Choirul Anam
# Purpose: Keep runtime state, credentials, and binary artifacts OUT of repo.
#          Source code (ilma_*.py, skills/, scripts/, ilma_bridges/, systemd/) IS tracked.
# ========================================================================

# ── Credentials & Secrets ──────────────────────────────────────────────────
# NEVER commit these — they contain API keys, tokens, passwords
/root/credential/
/root/.hermes/profiles/ilma/auth.json
/root/.hermes/profiles/ilma/auth.lock
/root/.hermes/profiles/ilma/.env
/root/.hermes/profiles/ilma/config.yaml
/root/.hermes/profiles/ilma/ilma_evidence_ledger.json

