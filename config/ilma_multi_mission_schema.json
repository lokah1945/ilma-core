{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ILMA Multi-Mission Schema",
  "description": "Schema for ILMA Phase 41 multi-mission orchestration cohort",
  "type": "object",
  "properties": {
    "cohort_id": {
      "type": "string",
      "description": "Unique cohort identifier"
    },
    "description": {
      "type": "string",
      "description": "Cohort description"
    },
    "missions": {
      "type": "object",
      "description": "Missions in the cohort",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "mission_id": {"type": "string"},
          "target_type": {"type": "string", "enum": ["LONGFORM", "CODEBASE", "RESEARCH", "LINUX_DISTRO"]},
          "goal": {"type": "string"},
          "priority": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
          "status": {"type": "string", "enum": ["PENDING", "ACTIVE", "BLOCKED", "COMPLETED", "FAILED"]},
          "blocked_reason": {"type": "string"},
          "quality_gates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "gate_name": {"type": "string"},
                "status": {"type": "string", "enum": ["PASS", "WARN", "FAIL"]},
                "evidence": {"type": "string"},
                "notes": {"type": "string"}
              }
            }
          },
          "evidence_ids": {
            "type": "array",
            "items": {"type": "string"}
          },
          "stages": {
            "type": "array",
            "items": {"type": "string"}
          },
          "checkpoint_id": {"type": "string"}
        },
        "required": ["mission_id", "target_type", "status"]
      }
    },
    "cross_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dep_id": {"type": "string"},
          "source_mission": {"type": "string"},
          "target_mission": {"type": "string"},
          "dep_type": {"type": "string", "enum": ["CONSUMES", "BLOCKS", "SHARES"]},
          "reason": {"type": "string"},
          "satisfied": {"type": "boolean"}
        },
        "required": ["dep_id", "source_mission", "target_mission", "dep_type"]
      }
    },
    "shared_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": {"type": "string"},
          "description": {"type": "string"},
          "source_path": {"type": "string"},
          "supported_missions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "created_at": {"type": "string"},
          "created_by": {"type": "string"}
        },
        "required": ["evidence_id", "source_path", "supported_missions"]
      }
    },
    "shared_working_buffer": {
      "type": "object",
      "description": "Key-value store shared across missions",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "key": {"type": "string"},
          "value": {},
          "source_mission": {"type": "string"},
          "timestamp": {"type": "string"},
          "previous_value": {},
          "overwritten": {"type": "boolean"}
        }
      }
    },
    "conflict_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "conflict_id": {"type": "string"},
          "conflict_type": {
            "type": "string",
            "enum": ["EVIDENCE_CONFLICT", "BUFFER_OVERWRITE", "CONTRADICTION", "OS_BUILD_FALSE_CLAIM", "INVALID_EVIDENCE"]
          },
          "missions_involved": {"type": "array", "items": {"type": "string"}},
          "description": {"type": "string"},
          "severity": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
          "detected_at": {"type": "string"},
          "resolved": {"type": "boolean"},
          "resolution": {"type": "string"}
        },
        "required": ["conflict_id", "conflict_type", "description", "severity"]
      }
    },
    "blocked_missions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "mission_id": {"type": "string"},
          "blocked_reason": {"type": "string"},
          "waiting_for": {"type": "string"}
        }
      }
    },
    "global_checkpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "checkpoint_id": {"type": "string"},
          "label": {"type": "string"},
          "timestamp": {"type": "string"},
          "mission_states": {"type": "object"},
          "dependencies": {"type": "array"},
          "shared_buffer": {"type": "object"},
          "shared_evidence": {"type": "array"},
          "conflicts": {"type": "array"},
          "created_at": {"type": "string"}
        },
        "required": ["checkpoint_id", "timestamp"]
      }
    },
    "per_mission_quality_gates": {
      "type": "object",
      "description": "Quality gate results per mission"
    },
    "global_quality_gate": {
      "type": "object",
      "properties": {
        "status": {"type": "string", "enum": ["PASS", "WARN", "FAIL"]},
        "checks": {"type": "array"},
        "warnings": {"type": "array"},
        "failures": {"type": "array"},
        "summary": {"type": "string"}
      }
    },
    "validator_reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "validator": {"type": "string"},
          "missions_reviewed": {"type": "array"},
          "result": {"type": "string"},
          "findings": {"type": "array"}
        }
      }
    },
    "final_status": {
      "type": "string",
      "enum": ["PENDING", "IN_PROGRESS", "COMPLETED", "FAILED", "BLOCKED"]
    },
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"}
  },
  "required": ["cohort_id", "missions", "cross_dependencies", "shared_evidence", "shared_working_buffer"]
}