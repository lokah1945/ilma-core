  "failure_to_lesson_map": {
    "parser_error": "lesson_parser_fix",
    "scope_violation": "lesson_negative_scope",
    "test_regression": "lesson_test_failure",
    "weak_verified": "lesson_evidence_backfill",
    "lesson_empty": "lesson_retrieval_targeting",
    "judge_fail": "lesson_judge_rubric",
    "trace_missing": "lesson_trace_schema",
    "duplicate_lessons": "lesson_dedup_fix",
    "reuse_not_incremented": "lesson_mark_reused"
  },
  "lifecycle_flow": {
    "step_1_intent": "user_message \u2192 intent_classifier \u2192 task_class",
    "step_2_plan": "task_class \u2192 task_planner \u2192 workflow + capabilities",
    "step_3_select": "workflow \u2192 runtime_router \u2192 tool/skill selection",
    "step_4_learn": "task \u2192 PreTaskLearningHook \u2192 retrieve_lessons",
    "step_5_execute": "tools \u2192 execute \u2192 artifact",
    "step_6_judge": "artifact \u2192 CriticJudge \u2192 score + status",
    "step_7_reflect": "judge=FAIL \u2192 ReflectionEngine \u2192 revision",
    "step_8_learn": "PASS/WARN \u2192 mark_reused \u2192 lesson saved",
    "step_9_trace": "all \u2192 trace_export \u2192 trace_file",
    "step_10_report": "final \u2192 voice \u2192 user_artifact"
  }
