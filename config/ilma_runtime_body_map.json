    "muscles": {
      "components": [
        "tools",
        "scripts",
        "skills",
        "CLI_actions"
      ],
      "inputs": [
        "tool_selection",
        "skill_selection"
      ],
      "outputs": [
        "executed_results",
        "artifacts"
      ],
      "files": [
        "scripts/",
        "skills/",
        "ilma_workflow_ecc.py"
      ]
    },
    "immune_system": {
      "components": [
        "security_scanner",
        "forbidden_scope_guard",
        "judge_evaluator",
        "rollback_engine"
      ],
      "inputs": [
        "execution_results",
        "artifact"
      ],
      "outputs": [
        "pass/warn/fail",
        "rollback_trigger"
      ],
      "files": [
        "scripts/ilma_critic_judge.py",
        "scripts/ilma_reflexion.py",
        "scripts/ilma_security_scanner.py"
      ]
    },
    "memory": {
      "components": [
        "lesson_memory",
        "evidence_ledger",
        "trace_archive"
