        "runtime_router",
        "capability_routing_matrix",
        "workflow_selector"
      ],
      "inputs": [
        "task_plan",
        "intent_classification"
      ],
      "outputs": [
        "workflow",
        "capability_selection"
      ],
      "files": [
        "config/ilma_runtime_routing_policy.json",
        "config/ilma_capability_routing_matrix.json"
      ]
