        "completed_tasks",
        "failures",
        "judge_results"
      ],
      "outputs": [
        "retrieved_lessons",
        "evidence_ids"
      ],
      "files": [
        "memory/ilma_lessons.jsonl",
        "evidence/"
      ]
    },
    "heartbeat": {
      "components": [
        "runner",
        "checkpoint_engine",
        "status_monitor",
        "health_check"
      ],
      "inputs": [
        "running_tasks",
        "cycles"
      ],
      "outputs": [
        "heartbeat_logs",
        "checkpoints",
        "status_reports"
      ],
      "files": [
        "scripts/ilma_phase48h_realtime_5min_canary.py",
        "scripts/ilma_phase49_autoloop_runner.py"
      ]
    },
    "senses": {
      "components": [
        "file_scanner",
        "test_runner",
        "log_parser",
        "judge_feedback_receiver"
      ],
      "inputs": [
        "filesystem",
        "test_results",
        "judge_scores"
      ],
      "outputs": [
        "observations",
        "quality_metrics"
      ],
      "files": [
        "scripts/",
        "tests/"
      ]
    },
    "voice": {
      "components": [
        "final_artifact_producer",
        "user_report_generator",
        "evidence_reporter"
