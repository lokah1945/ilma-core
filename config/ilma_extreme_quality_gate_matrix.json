        "evidence_required": true,
        "blocking": false
      },
      "claim_ledger": {
        "check": "All major claims tracked with evidence IDs",
        "validator": "EvidenceAuditor",
        "evidence_required": true,
        "blocking": true
      }
    },
    "CODEBASE": {
