{
  "schema_version": "1.0",
  "phase": "47",
  "date": "2026-05-10",
  "description": "Schema for evolution traces generated by Autonomous Evolution loop",

  "fields": {
    "trace_id": {
      "type": "string",
      "format": "TRACE-YYYYMMDDHHMMSS-XXX",
      "required": true,
      "description": "Unique trace identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "ISO8601",
      "required": true,
      "description": "Creation timestamp"
    },
    "target": {
      "type": "string",
      "required": true,
      "description": "Task target/goal"
    },
    "task_class": {
      "type": "string",
      "enum": ["simple", "normal", "heavy", "super_heavy", "extreme_mission", "autonomous_evolution"],
      "required": true
    },
    "start_time": {
      "type": "string",
      "format": "ISO8601",
      "required": true
    },
    "end_time": {
      "type": "string",
      "format": "ISO8601",
      "required": false
    },
    "iteration_count": {
      "type": "integer",
      "minimum": 0,
      "required": true
    },
    "retrieved_lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "lesson_id": {"type": "string"},
          "task_type": {"type": "string"},
          "relevance_score": {"type": "number"}
        }
      }
    },
    "actor_outputs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "judge_results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "status": {"type": "string"},
          "score": {"type": "number"},
          "failures": {"type": "array"},
          "warnings": {"type": "array"},
          "evidence_ids": {"type": "array"}
        }
      }
    },
    "reflections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "root_cause": {"type": "string"},
          "failed_assumption": {"type": "string"},
          "fix_plan": {"type": "array"},
          "lesson_candidate": {"type": "object"}
        }
      }
    },
    "revisions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "final_status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED", "ESCALATED", "DIRECT_EXECUTE", "NO_JUDGE", "ERROR"],
      "required": true
    },
    "lessons_created": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "blocked_reason": {
      "type": "string",
      "required": false
    },
    "exit_reason": {
      "type": "string",
      "required": true
    },
    "error": {
      "type": "string",
      "required": false
    }
  },

  "validation": {
    "required_fields": ["trace_id", "timestamp", "target", "task_class", "start_time", "final_status", "exit_reason"],
    "unique_trace_id": true,
    "iterations_match_actor_outputs": true,
    "judge_results_match_reflections": true
  }
}