{
  "config_version": "1.0",
  "phase": "47",
  "date": "2026-05-10",
  "description": "Persistent configuration for Autonomous Evolution Nerve Integration",

  "enabled": true,
  "mode": "guarded_persistent",

  "default_for_task_classes": [
    "heavy",
    "super_heavy",
    "extreme_mission",
    "autonomous_evolution"
  ],

  "max_iterations": {
    "simple": 20,
    "normal": 30,
    "heavy": 80,
    "super_heavy": 160,
    "extreme_mission": 300,
    "autonomous_evolution": 300
  },

  "checkpoint_every_iterations": 5,
  "checkpoint_dir": "memory/evolution_checkpoints/",

  "lesson_retrieval_top_k": 5,
  "lesson_memory_path": "memory/ilma_lessons.jsonl",
  "lesson_schema_path": "memory/ilma_lesson_schema.json",

  "judge_threshold_pass": 85,
  "judge_threshold_warn": 70,

  "auto_store_lessons": true,
  "require_human_for": [
    "dependency_install",
    "network_credentials",
    "production_deployment",
    "destructive_file_operation",
    "external_publish",
    "os_build"
  ],

  "contract_version": "1.0",
  "contract_path": "config/ilma_autonomous_evolution_contract.json",

  "pre_task_hook": "scripts/ilma_pretask_learning_hook.py",
  "orchestrator": "scripts/ilma_autonomous_evolution_orchestrator.py",
  "judge": "scripts/ilma_critic_judge.py",
  "reflection": "scripts/ilma_reflection_engine.py",
  "memory": "scripts/ilma_lesson_memory.py",
  "router": "scripts/ilma_conditional_loop_router.py",
  "validators": "scripts/ilma_specialist_validators.py",

  "trace_dir": "evidence/evolution_traces/",
  "trace_schema_path": "config/ilma_evolution_trace_schema.json",

  "no_overclaim_gate": true,
  "truth_section_required": true,

  "safety": {
    "unsafe_abort": true,
    "max_iterations_hard": true,
    "checkpoint_on_crash": true,
    "rollback_on_corrupt": true
  }
}