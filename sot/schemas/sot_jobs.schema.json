{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "sot_jobs",
  "description": "SOT operational jobs registry. Tracks scheduled/running/completed sync, enrichment, materialization jobs with idempotency lock.",
  "type": "object",
  "required": [
    "job_id",
    "job_type",
    "status",
    "started_at",
    "actor"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "description": "Unique job id (e.g. ILMA-EVID-style or UUID)"
    },
    "job_type": {
      "type": "string",
      "enum": [
        "provider_sync",
        "enrichment",
        "materialize",
        "backup",
        "validate",
        "audit_sweep"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "success", "error", "cancelled"]
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "actor": { "type": "string" },
    "result": {
      "type": "object",
      "description": "Job-specific result payload (counts, errors, etc.)"
    },
    "idempotency_key": {
      "type": "string",
      "description": "Lock key to prevent concurrent runs of the same job"
    },
    "evidence_id": { "type": "string" },
    "error": { "type": "string" }
  }
}
